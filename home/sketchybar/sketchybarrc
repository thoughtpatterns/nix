#!/usr/bin/env janet

# Pixel measurements are for [2056 × 1329]; notch has height ~38.

(use spork/sh-dsl)

(defmacro defbracket [name position]
  (defn cat [x] (symbol (string name "/" x)))
  (def store (cat "store"))
  (def push (cat "push"))
  ~(upscope
     (def ,store @[])
     (defn ,push [x] (array/push ,store x) ["item" x ,position])))

(defbracket spaces "left")
(defbracket meters "right")
(defbracket clock "right")

(defn pairs [x] (seq [[k v] :pairs x] (string k "=" v)))
(defn script [x] (string "script=" (os/getenv "CONFIG_DIR") "/plugins/" x))

(def border_width 1)

(def bar {:color "0x00000000"
          :height 24
          :y_offset 16})

(def bracket {:background.border_color "0xfffdfdfa"
              :background.border_width border_width
              :background.color "0xff4b5363"
              :background.corner_radius 0
              :background.drawing true
              :background.height 24})

(def default {:icon.drawing false
              :label.color "0xfffdfdfa"
              :label.font "Iosevka Nerd Font Mono:Regular:14.0"
              :label.padding_left 0
              :label.padding_right 0
              :padding_left 12
              :padding_right 12})

(def space {:background.color "0xff686868"
            :background.drawing false
            :background.padding_left border_width
            :background.padding_right border_width
            :label.padding_left 12
            :label.padding_right 12})

(def spaces @["--add" "event" "aerospace_workspace_change"])
(each n (string/split "\n" ($<_ aerospace list-workspaces --all))
  (let [x (string "space." n)]
    (array/push spaces
                "--add" ;(spaces/push x)
                "--subscribe" x "aerospace_workspace_change"
                "--set" x ;(pairs space) (string "label=" n) (script (string "aerospace " n)))))

($ sketchybar
   --bar ;(pairs bar)
   --default ;(pairs default)

   ;spaces

   # --add ;(info/push "front")
   # --set front "icon.drawing=off" (script "front")
   # --subscribe front front_app_switched

   --add ;(clock/push "clock")
   --set clock ;(pairs {:update_freq 1}) (script "clock")

   --add item spacer/clock-meters right
   --set spacer/clock-meters ;(pairs {:width 8 :background.drawing false})

   --add ;(meters/push "volume")
   --set volume (script "volume")
   --subscribe volume volume_change

   --add ;(meters/push "battery")
   --set battery ;(pairs {:update_freq 120}) (script "battery")
   --subscribe battery system_woke power_source_change

   --add bracket bracket/spaces ;spaces/store
   --set bracket/spaces ;(pairs bracket)

   --add bracket bracket/meters ;meters/store
   --set bracket/meters ;(pairs bracket)

   --add bracket bracket/clock ;clock/store
   --set bracket/clock ;(pairs bracket)

   --update)
