[user]
email = "moe.m.makki@gmail.com"
name = "Mohamad Makki"
signingKey = "~/.ssh/id_ed25519.pub"

[init]
defaultBranch = "main"

[tag]
gpgSign = true

[commit]
gpgsign = true

[gpg]
format = "ssh"

[gpg "ssh"]
allowedSignersFile = "/Users/moe/.config/git/allowed_signers"
program = "ssh-keygen"

[credential "https://gist.github.com"]
helper = "gh auth git-credential"

[credential "https://github.com"]
helper = "gh auth git-credential"

[filter "lfs"]
clean = "git-lfs clean -- %f"
process = "git-lfs filter-process"
required = true
smudge = "git-lfs smudge -- %f"
